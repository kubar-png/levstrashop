# ── Sanity ───────────────────────────────────────────────
# Create a free project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Write token (Editor permissions). Required for stock decrement + order persistence.
SANITY_API_WRITE_TOKEN=

# ── Stripe (secondary payment provider) ──────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Set after running `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Comgate (primary CZ payment provider) ────────────────
# Get keys from https://portal.comgate.cz
COMGATE_MERCHANT_ID=
COMGATE_SECRET=
COMGATE_TEST=true

# ── PPL myAPI ────────────────────────────────────────────
# Request from your PPL account manager (you need a business contract)
PPL_API_BASE=https://api.dhl.com/parcel/cz/myapi/v4
PPL_CLIENT_ID=
PPL_CLIENT_SECRET=
PPL_CUSTOMER_REF=

# ── Resend (transactional email) ─────────────────────────
# 1. Sign up at https://resend.com — 3 000 e-mails/měsíc zdarma
# 2. Add domain levstra.cz, set the SPF + DKIM DNS records they show
# 3. Create API key → paste below
# 4. Use a verified subdomain or root domain in the "from" addresses
RESEND_API_KEY=
RESEND_FROM_ORDERS="Levstra <objednavky@levstra.cz>"
RESEND_FROM_CONTACT="Levstra <info@levstra.cz>"
RESEND_REPLY_TO=info@levstra.cz
RESEND_INTERNAL_INBOX=info@levstra.cz

# ── Sanity webhook ────────────────────────────────────────
# Secret pro ověření webhooku, který přijímá změny statusu objednávky
# (např. odesláno → spustí shipping e-mail). Vygeneruje se v Sanity manage →
# API → Webhooks → Create.
SANITY_ORDER_WEBHOOK_SECRET=

# ── Ecomail (newsletter + marketing automations) ─────────
# 1. Sign up at https://ecomailapp.cz (CZ-based, GDPR-friendly)
# 2. Add domain levstra.cz with a DIFFERENT DKIM selector than Resend
#    (e.g. "ecomail._domainkey" so reputations stay separate)
# 3. Settings → Integrations → API → create key
# 4. Create a list "Newsletter" → copy numeric ID
# 5. ECOMAIL_APP_ID = your Ecomail account subdomain (eg. "levstra")
ECOMAIL_API_KEY=
ECOMAIL_LIST_ID=
ECOMAIL_APP_ID=levstra

# ── Storefront ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=CZK
NEXT_PUBLIC_LOCALE=cs-CZ
